{
  "name": "Iskra Numpad",
  "maintainers": ["VostokLabs"],
  "features": ["keys"],
  "matrix": { "rows": 2, "cols": 5, "diode_direction": "COL2ROW" },
  "layouts": {
    "keymap": {
      "layout": [
        { "x": 0, "y": 0, "row": 0, "col": 0 },
        { "x": 1, "y": 0, "row": 0, "col": 1 },
        { "x": 2, "y": 0, "row": 0, "col": 2 },
        { "x": 3, "y": 0, "row": 0, "col": 3 },
        { "x": 4, "y": 0, "row": 0, "col": 4 },

        { "x": 0, "y": 1, "row": 1, "col": 0 },
        { "x": 1, "y": 1, "row": 1, "col": 1 },
        { "x": 2, "y": 1, "row": 1, "col": 2 },
        { "x": 3, "y": 1, "row": 1, "col": 3 },
        { "x": 4, "y": 1, "row": 1, "col": 4 }
      ]
    }
  }
}